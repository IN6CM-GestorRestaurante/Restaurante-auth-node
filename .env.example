# Copiar a .env: cp .env.example .env
#
# Puertos:
#   Local (pnpm dev): 3000
#   Docker Compose:   3007

NODE_ENV=development
PORT=3000

# PostgreSQL - Desarrollo local / Docker
DATABASE_URL=postgresql://postgres:admin@localhost:5432/restaurante_auth_db

# PostgreSQL - Variables alternativas
DB_HOST=localhost
DB_PORT=5432
DB_NAME=restaurante_auth_db
DB_USERNAME=postgres
DB_PASSWORD=admin

# JWT (debe coincidir con restaurante-auth-service y restaurante-server-admin)
JWT_SECRET=Restaurante_Super_Secret_Key_2026_DotNet8
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=30d
REFRESH_TOKEN_EXPIRES_DAYS=30
ACCESS_TOKEN_EXPIRES_MINUTES=480
JWT_ISSUER=auth-service
JWT_AUDIENCE=restaurante-app

# URL para el cliente de sincronización con server-admin
ADMIN_SERVICE_URL=http://localhost:3001

# URL de ServerUser (MongoDB) - aqui se sincroniza el registro espejo del
# usuario al registrarse (POST /users/sync), protegido con JWT_SECRET
USER_SERVICE_URL=http://localhost:3003

# SMTP Configuration (para envío de emails, e.g., Mailtrap / Gmail)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_ENABLE_SSL=true
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@restaurante.app
SMTP_FROM_NAME=Gestor Restaurante

# Cloudinary - Perfiles de usuario (copiar del ServerAdmin en docker-compose)
CLOUDINARY_CLOUD_NAME=dueikakf8
CLOUDINARY_API_KEY=119292848621234
CLOUDINARY_API_SECRET=ckVTJkNQUjUatlwOcYFMg-9hAyM
CLOUDINARY_BASE_URL=https://res.cloudinary.com/dueikakf8/image/upload/
CLOUDINARY_FOLDER=auth_service/profiles
CLOUDINARY_DEFAULT_AVATAR_FILENAME=avatar-default.png

# Uploads locales (fallback)
UPLOAD_PATH=./uploads/profiles/

# Seguridad
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME_MS=1800000
VERIFICATION_EMAIL_EXPIRY_HOURS=24
PASSWORD_RESET_EXPIRY_HOURS=1

# App / CORS
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001,http://localhost:3000
ADMIN_ALLOWED_ORIGINS=http://localhost:5173

# IP filtering (opcional)
BLACKLISTED_IPS=
WHITELISTED_IPS=
RESTRICTED_PATHS=/api/v1/admin
